    "@mzinga/plugin-seo": "../packages/plugin-seo",
    "@mzinga/richtext-slate": "../packages/richtext-slate",
    "dotenv": "^17.2.3",
    "express": "^4.19.2",
    "jsoneditor-react": "^3.1.2",
    "monaco-editor": "^0.52.2",
    "mzinga": "../packages/mzinga",
