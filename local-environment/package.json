{
  "name": "mzinga-local-environment",
  "description": "The local environment for MZinga",
  "version": "1.0.0",
  "main": "dist/server.js",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env PAYLOAD_SEED=true PAYLOAD_DROP_DATABASE=true PAYLOAD_CONFIG_PATH=src/mzinga.config.ts nodemon",
    "generate:types": "cross-env PAYLOAD_CONFIG_PATH=src/mzinga.config.ts mzinga generate:types",
    "generate:graphQLSchema": "PAYLOAD_CONFIG_PATH=src/mzinga.config.ts mzinga generate:graphQLSchema"
  },
  "dependencies": {
    "@mzinga/bundler-webpack": "../packages/bundler-webpack",
    "@mzinga/db-mongodb": "../packages/db-mongodb",
    "@mzinga/richtext-slate": "../packages/richtext-slate",
    "@faceless-ui/modal": "2.0.2",
    "@mzinga/plugin-form-builder": "../packages/plugin-form-builder",
    "@mzinga/plugin-seo": "../packages/plugin-seo",
    "dotenv": "^17.2.3",
    "express": "^4.19.2",
    "mzinga": "../packages/mzinga"
  },
  "devDependencies": {
    "@types/express": "^4.17.9",
    "copyfiles": "^2.4.1",
    "cross-env": "^7.0.3",
    "nodemon": "^2.0.6",
    "ts-node": "^9.1.1",
    "typescript": "5.9.3"
  }
}